# =============================================================================
# .env.example — ClearSolve (Personal Browser-Native NLHE GTO Solver)
# -----------------------------------------------------------------------------
# This app has NO BACKEND (CON-2) and stores NO user data off-device (NFR-006).
# At RUNTIME the app needs essentially NO secrets. The only env-style values are:
#   (a) build-time, public, Vite `VITE_`-prefixed flags (these are INLINED into
#       the client bundle and are therefore NOT secret), and
#   (b) CI/deploy tokens that live ONLY in GitHub Actions secrets, NOT here.
#
# Copy to `.env.local` (gitignored) for local dev overrides. NEVER put real
# secret values in any committed file.
# =============================================================================

# --- Build-time, PUBLIC client flags (safe to commit; inlined into the bundle) ---
# App display/version string surfaced in the UI (EDGE-008 version-mismatch checks
# use the engineVersion from the WASM, this is just a UI label).
VITE_APP_VERSION=0.0.0-dev

# Force single-thread engine even when cross-origin isolated (debugging RISK-006).
# Leave false; the app auto-detects `crossOriginIsolated` (ADR-003).
VITE_FORCE_SINGLE_THREAD=false

# Path prefix where the predefined library index/shards are served from.
VITE_LIBRARY_BASE_PATH=/library

# Optional: enable the in-app debug log ring buffer (ARCHITECTURE Sec 14).
VITE_DEBUG_PANEL=false

# --- Analytics: INTENTIONALLY NONE in MVP (NFR-006, no data leaves the device) ---
# If a privacy-preserving, self-hostable analytic is EVER added (would require an
# approval gate + a CSP connect-src change + COEP/CORP review), it would go here
# as a PUBLIC key. Left commented and empty by design.
# VITE_ANALYTICS_KEY=

# =============================================================================
# CI / DEPLOY SECRETS — DO NOT PUT VALUES HERE. Set these in GitHub repo
# Settings > Secrets and variables > Actions. Listed for documentation only.
# =============================================================================
# CLOUDFLARE_API_TOKEN      # scoped Pages:Edit token (deploy.yml) — host = ADR-008
# CLOUDFLARE_ACCOUNT_ID     # Cloudflare account id (not strictly secret, but kept out of repo)
# (Netlify alternative)     # NETLIFY_AUTH_TOKEN, NETLIFY_SITE_ID
